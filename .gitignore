# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.py~

# Environment
.env
.env.local
.env.*
!.env.example

# Databases
*.db
*.db-shm
*.db-wal

# The entire data/ directory is runtime/scratch (SQLite db, WAL, server logs, gate
# output dumps) and may contain real or test PII. This repo is PUBLIC — never commit
# anything under data/ except the .gitkeep placeholder that preserves the directory.
data/*
!data/.gitkeep

# Operator-console runtime incident data — may contain PII; never commit (public repo).
console/incidents.json

# Backup files
*.bak*
*.bak

# Runtime logs
.verify-logs/
output/playwright/
*.log
